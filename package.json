{
  "name": "ampledge-dashboard",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "aws-amplify": "^6.16.4",
    "chart.js": "^4.5.1",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "ldrs": "^1.1.9",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "react-simple-maps": "^3.0.0",
    "topojson-client": "^3.1.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "s3-sync": "node scripts/deploy-s3.mjs",
    "invalidate": "node -e \"require('dotenv').config(); const d = process.env.DISTRIBUTION_ID; if (!d) { console.log('Skipping CloudFront invalidation'); process.exit(0); } console.log('Invalidating:', d); require('child_process').execSync(`aws cloudfront create-invalidation --distribution-id ${d} --paths \"/*\"`, { stdio: 'inherit' });\"",
    "setup-cloudfront": "node scripts/setup-cloudfront-errors.mjs",
    "deploy": "npm run build && npm run s3-sync && npm run invalidate"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "gh-pages": "^6.3.0"
  }
}
